{"nodes": [{"id": "docs_project_structure_doc", "label": "Project Structure (docs)", "file_type": "document", "source_file": "docs/project-structure.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "concept_path_alias_convention", "label": "Path alias convention (tsconfig/babel)", "file_type": "rationale", "source_file": "docs/project-structure.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Imports use path aliases (@components/*, @screens/*, etc.) defined in tsconfig.json and babel.config.js; aliases must stay aligned when moving/renaming folders."}, {"id": "src_components_boundary", "label": "components/ folder boundary (presentational UI)", "file_type": "rationale", "source_file": "docs/project-structure.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Components should stay presentational, receiving data/callbacks from screens; ScreenContainer is a documented intentional exception that reads settings/navigation state."}, {"id": "src_config_boundary", "label": "config/ folder boundary (static constants)", "file_type": "rationale", "source_file": "docs/project-structure.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "config/ centralizes app constants and conference metadata; must avoid side effects and runtime state, keeping values static and deterministic."}, {"id": "src_data_boundary", "label": "data/ folder boundary (declarative content)", "file_type": "rationale", "source_file": "docs/project-structure.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "data/ holds static bundled content only; no runtime logic or dynamic fetches allowed."}, {"id": "src_hooks_boundary", "label": "hooks/ folder boundary (shared side-effect logic)", "file_type": "rationale", "source_file": "docs/project-structure.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "hooks/ hosts logic spanning multiple screens/components, especially side-effectful flows; hooks should not render UI."}, {"id": "src_navigation_boundary", "label": "navigation/ folder boundary (routing only)", "file_type": "rationale", "source_file": "docs/project-structure.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "navigation/ centralizes route names, typed param lists, and stack/tab registration; must not reach into services or stores."}, {"id": "src_screens_boundary", "label": "screens/ folder boundary (orchestration)", "file_type": "rationale", "source_file": "docs/project-structure.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "screens/ are top-level views orchestrating data loading/state/layout for a route; reusable UI belongs in components/, logic in hooks/ or utils/."}, {"id": "src_services_boundary", "label": "services/ folder boundary (data access only)", "file_type": "rationale", "source_file": "docs/project-structure.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "services/ handles data access and normalization (network requests, caching); must avoid UI, navigation, or direct component coupling, returning typed data only."}, {"id": "src_store_boundary", "label": "store/ folder boundary (global state + persistence)", "file_type": "rationale", "source_file": "docs/project-structure.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "store/ contains global state containers and persistence for settings, conference data, and favorites; data parsing belongs in services/, not store/."}, {"id": "src_types_boundary", "label": "types/ folder boundary (types only)", "file_type": "rationale", "source_file": "docs/project-structure.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "types/ holds TypeScript interfaces for raw API payloads and normalized app models; no runtime code."}, {"id": "src_utils_boundary", "label": "utils/ folder boundary (pure helpers + isolated side effects)", "file_type": "rationale", "source_file": "docs/project-structure.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "utils/ holds pure helpers and isolated side-effect wrappers (formatting, time, notifications, calendar, storage); avoid React hooks and UI to keep logic testable."}], "edges": [{"source": "docs_project_structure_doc", "target": "concept_path_alias_convention", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/project-structure.md", "source_location": null, "weight": 1.0}, {"source": "docs_project_structure_doc", "target": "src_components_boundary", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/project-structure.md", "source_location": null, "weight": 1.0}, {"source": "docs_project_structure_doc", "target": "src_config_boundary", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/project-structure.md", "source_location": null, "weight": 1.0}, {"source": "docs_project_structure_doc", "target": "src_data_boundary", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/project-structure.md", "source_location": null, "weight": 1.0}, {"source": "docs_project_structure_doc", "target": "src_hooks_boundary", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/project-s